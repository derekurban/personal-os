{
  "name": "personal-os",
  "version": "0.1.0",
  "type": "module",
  "types": "./dist/index.d.ts",
  "bin": {
    "personalos": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "docs",
    "storage/README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "cli": "tsx src/cli.ts",
    "test": "tsx --test tests/**/*.test.ts",
    "storage:init": "tsx src/cli.ts init",
    "storage:ingest": "tsx src/cli.ts ingest",
    "storage:doctor": "tsx src/cli.ts doctor",
    "storage:repair": "tsx src/cli.ts repair",
    "ingest": "tsx src/cli.ts ingest",
    "doctor": "tsx src/cli.ts doctor",
    "repair": "tsx src/cli.ts repair"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  }
}
